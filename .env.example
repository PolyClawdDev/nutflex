# Optional: default IPTV source (Xtream) — seeded on first run when no sources exist.
# Copy to .env and fill in, then: sudo systemctl restart netv
NETV_DEFAULT_SOURCE_URL=https://s.rocketdns.info
NETV_DEFAULT_SOURCE_NAME=My IPTV
NETV_DEFAULT_SOURCE_USER=8951349
NETV_DEFAULT_SOURCE_PASS=your_password_here

# Optional: admin user created at first run when no users exist (username:password).
# NETV_ADMIN=admin:your_admin_password
